# Unison Brain API credentials
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# Required: your Unison API token (get one at https://unisonlabs.ai or via
# `curl -X POST https://brain.unisonlabs.ai/v1/auth/provision -H 'Content-Type: application/json' -d '{"email":"you@example.com"}'`)
UNISON_TOKEN=usk_live_...

# Optional: override the API base URL (e.g. for a self-hosted or staging brain)
UNISON_API_URL=https://brain.unisonlabs.ai
